{
  "name": "@team/web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web",
  "projectType": "application",
  "tags": [],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "apps/web"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build --webpack",
        "cwd": "apps/web"
      }
    },
    "cf:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn cf:build",
        "cwd": "apps/web"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["cf:build"],
      "options": {
        "command": "yarn wrangler pages deploy",
        "cwd": "apps/web"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start",
        "cwd": "apps/web"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "apps/web"
      }
    }
  }
}
